# tokenopt development rules
# Standard Python/FastAPI project toolchain (Windows + Linux/macOS)

prefix_rule(pattern = ["python"], decision = "allow")
prefix_rule(pattern = ["pip"], decision = "allow")
prefix_rule(pattern = ["py"], decision = "allow")
prefix_rule(pattern = ["pytest"], decision = "allow")
prefix_rule(pattern = ["black"], decision = "allow")
prefix_rule(pattern = ["ruff"], decision = "allow")
prefix_rule(pattern = ["git"], decision = "allow")
prefix_rule(pattern = ["uvicorn"], decision = "allow")
prefix_rule(pattern = ["cmd"], decision = "allow")
prefix_rule(pattern = ["powershell"], decision = "allow")
prefix_rule(pattern = ["bash"], decision = "allow")
prefix_rule(pattern = ["sh"], decision = "allow")
